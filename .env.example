# QuantResearch Agent — Configuração de API Keys
# =============================================
# Copie este arquivo para .env e preencha suas chaves:
#   cp .env.example .env
#
# NUNCA comite o arquivo .env no git!
# O arquivo .env já está no .gitignore.

# ─── AÇÕES E FUTUROS ──────────────────────────────────────────
# Alpaca Markets — Gratuito, criar conta em: https://alpaca.markets
# Já inclui 10 anos de dados históricos de 1min para pesquisa
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # ou https://api.alpaca.markets para live

# Polygon.io — Planos a partir de $29/mo: https://polygon.io
# Cupom de 20% para estudantes: https://www.studentbeans.com/student-discount/us/polygon-io
POLYGON_API_KEY=

# Tiingo — $10/mo para pesquisa de longo prazo: https://www.tiingo.com
TIINGO_API_KEY=

# Databento — $125 créditos grátis ao criar conta: https://databento.com
# Melhor para tick data e futuros CME
DATABENTO_API_KEY=

# ─── MACRO ────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — 100% GRATUITO
# Obter chave em: https://fred.stlouisfed.org/api_key
FRED_API_KEY=

# ─── CRIPTOATIVOS ─────────────────────────────────────────────
# Binance — Criar conta em: https://binance.com
# Dados públicos OHLCV gratuitos sem autenticação
# API key necessária apenas para trading ou rate limits maiores
BINANCE_API_KEY=
BINANCE_SECRET=

# CoinGecko — Tier gratuito disponível: https://www.coingecko.com/en/api
# 15% OFF em qualquer plano pago via: https://www.coingecko.com/en/candy/rewards/coingecko-api-plans-15-for-any-coingecko-api-subscription
COINGECKO_API_KEY=

# ─── MERCADOS DE PREDIÇÃO ─────────────────────────────────────
# Kalshi — CFTC regulado, dados públicos gratuitos: https://kalshi.com
# Criar conta para obter API key (necessária para trading)
KALSHI_API_KEY=
KALSHI_EMAIL=
KALSHI_PASSWORD=
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# Polymarket — Descentralizado, leitura 100% gratuita sem autenticação
# Private key Ethereum necessária apenas para executar trades
POLYMARKET_PRIVATE_KEY=

# ─── CONFIGURAÇÕES GERAIS ─────────────────────────────────────
# Diretório base de dados (relativo ao projeto)
DATA_DIR=data

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Timeout padrão para requisições HTTP (segundos)
REQUEST_TIMEOUT=30
